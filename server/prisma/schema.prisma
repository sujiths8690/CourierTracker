generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Customer {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(30)
  address        String           @db.Text
  lat            Float
  lng            Float
  isActive       Boolean          @default(true)
  mobileNumber   String?          @db.VarChar(13)
  VehicleBooking VehicleBooking[]

  createdAt       DateTime?        @default(now())
  updatedAt       DateTime?        @updatedAt
}

model Driver{
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(30)
  mobileNumber   String           @db.VarChar(15)

  createdAt       DateTime?        @default(now())
  updatedAt       DateTime?        @updatedAt
}

model TrackingLog {
  id             Int            @id @default(autoincrement())
  bookingId      Int
  lat            Float
  createdAt      DateTime       @default(now())
  lng            Float
  VehicleBooking VehicleBooking @relation(fields: [bookingId], references: [id])

  @@index([bookingId, createdAt])
}

model User {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(50)
  email          String           @unique @db.VarChar(90)
  type           User_type?       @default(STAFF)
  password       String
  isActive       Boolean?         @default(true)
  VehicleBooking VehicleBooking[]

  createdAt      DateTime?         @default(now())
  updatedAt      DateTime?         @updatedAt
}

model VehicleBooking {
  id             Int                   @id @default(autoincrement())
  vehicleId      Int
  pickupLat      Float
  destLat        Float
  status         VehicleBooking_status @default(PENDING)
  trackingToken  String                @unique
  createdAt      DateTime              @default(now())
  updatedAt      DateTime               @updatedAt
  route          Json?
  destLng        Float
  pickupLng      Float
  lastLat        Float?
  lastLng        Float?
  lastUpdated    DateTime?
  userId         Int?
  isActive       Boolean               @default(true)
  customerId     Int
  destAddress    String
  pickupAddress  String
  bookingId      String                @unique @db.VarChar(20)
  TrackingLog    TrackingLog[]
  Customer       Customer              @relation(fields: [customerId], references: [id])
  User           User?                 @relation(fields: [userId], references: [id])
  VehicleDetails VehicleDetails        @relation(fields: [vehicleId], references: [id])

  @@index([customerId], map: "VehicleBooking_customerId_fkey")
  @@index([userId], map: "VehicleBooking_userId_fkey")
  @@index([vehicleId], map: "VehicleBooking_vehicleId_fkey")
}

model VehicleDetails {
  id             Int                   @id @default(autoincrement())
  number         String                @unique @db.VarChar(100)
  type           VehicleDetails_type   @default(TRUCK)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  status         VehicleDetails_status @default(AVAILABLE)
  isActive       Boolean?              @default(true)
  lastLat        Float?
  lastUpdated    DateTime?
  pricePerKm     Float?                @default(10)
  lastLng        Float?
  VehicleBooking VehicleBooking[]
  VehicleUser    VehicleUser[]
}

model VehicleUser {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(30)
  type           VehicleUser_type @default(DRIVER)
  mobileNumber   String
  password       String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  vehicleId      Int
  isActive       Boolean          @default(true)
  VehicleDetails VehicleDetails   @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId], map: "VehicleUser_vehicleId_fkey")
}

enum VehicleUser_type {
  OWNER
  DRIVER
}

enum VehicleDetails_type {
  TRUCK
  PICKUP
}

enum User_type {
  ADMIN
  STAFF
}

enum VehicleBooking_status {
  PENDING
  ONGOING
  COMPLETED
  CANCELLED
  LOADING
}

enum VehicleDetails_status {
  AVAILABLE
  BUSY
}
